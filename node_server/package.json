{
  "name": "nodejs-express-template",
  "version": "1.0.0",
  "description": "Scalable and basic template for making Node.js apps by using express",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "seed:octaprice": "node seed-octaprice.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier-eslint \"$PWD/{,!(node_modules)/**/}*.{js,json}\"",
    "format:fix": "prettier-eslint --write \"$PWD/{,!(node_modules)/**/}*.{js,json}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "lint-staged": {
    "*.js": [
      "npm run lint:fix",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@adminjs/express": "^4.1.3",
    "@adminjs/mongoose": "^2.0.4",
    "@hapi/joi": "^17.1.1",
    "adm-zip": "^0.5.17",
    "adminjs": "^5.11.0",
    "bcrypt": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-ip": "^1.0.4",
    "express-session": "^1.18.1",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "xlsx": "^0.18.5"
  }
}
